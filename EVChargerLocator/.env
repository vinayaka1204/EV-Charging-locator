# ⚡ EV Charger Locator Environment Variables

# ==========================================
# AWS Backend Settings
# ==========================================
# The name of your DynamoDB table
TABLE_NAME=EVChargers

# ==========================================
# Frontend Configuration
# ==========================================
# Replace with the URL given by AWS API Gateway after deployment
API_BASE_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod

# Replace with your actual Google Maps JavaScript API Key
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
